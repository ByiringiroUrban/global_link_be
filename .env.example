# PostgreSQL
POSTGRES_USER=global_link
POSTGRES_PASSWORD=global_link_secret
POSTGRES_DB=global_link_db
DATABASE_URL=postgresql://global_link:global_link_secret@localhost:5432/global_link_db?schema=public

# Backend (Express + AI – single Node.js process)
PORT=3000
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
UPLOAD_DIR=uploads

# Email (optional – logs to console in development)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@globallink.com
