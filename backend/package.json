{
  "name": "global-link-backend",
  "version": "1.0.0",
  "description": "Global Link Ecommerce, Warehouse Management & AI - unified Node.js backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "tsx scripts/prisma.ts generate",
    "db:migrate": "tsx scripts/prisma.ts migrate dev",
    "db:push": "tsx scripts/prisma.ts db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "tsx scripts/prisma.ts studio"
  },
  "keywords": ["ecommerce", "warehouse", "global-link", "ai"],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "nodemailer": "^7.0.3",
    "sharp": "^0.34.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.21",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
